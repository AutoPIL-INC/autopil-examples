ANTHROPIC_API_KEY=your-key-here

# Alternatives — leave ANTHROPIC_API_KEY unset to use one of these instead:

# Gemini — free at https://aistudio.google.com/apikey
# GOOGLE_API_KEY=your-key-here

# Groq — free at https://console.groq.com/keys, fast, hosts Llama 3.3/4
# GROQ_API_KEY=your-key-here

# Ollama — fully local, no key. Needs `ollama serve` running and the model pulled
# (default: qwen2.5:7b — `ollama pull qwen2.5:7b`; verified to actually use tools
# reliably. Smaller models like llama3.2 tend to skip tool calls entirely — tested,
# not guessed). Set OLLAMA_MODEL to use a different one.
# OLLAMA_MODEL=qwen2.5:7b
