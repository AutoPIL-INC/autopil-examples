ANTHROPIC_API_KEY=your-key-here

# Alternatives — leave ANTHROPIC_API_KEY unset to use one of these instead:

# Gemini — free at https://aistudio.google.com/apikey
# GOOGLE_API_KEY=your-key-here

# Groq — free at https://console.groq.com/keys, fast, hosts Llama 3.3/4
# GROQ_API_KEY=your-key-here

# Ollama — fully local, no key. Needs `ollama serve` running and the model pulled
# (default: qwen2.5:7b — `ollama pull qwen2.5:7b`; verified to actually use tools
# reliably. Smaller models like llama3.2 tend to skip tool calls entirely — tested,
# not guessed). Set OLLAMA_MODEL to use a different one.
# OLLAMA_MODEL=qwen2.5:7b

# AWS Bedrock — used by the client_analysis demo (Bedrock-first provider there).
# Requires AWS credentials configured the normal way (env vars, ~/.aws/credentials, or
# an SSO profile via AWS_PROFILE) plus access enabled for the model in the Bedrock
# console. AWS_BEDROCK_MODEL_ID being set is what opts a run into Bedrock — nothing
# here is auto-detected from ambient AWS credentials.
# AWS_BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
# AWS_REGION=us-east-1

# Hosted AutoPIL SaaS trial — opt the fraud_investigation demo into calling a real
# hosted AutoPIL instance (POST /v1/context/evaluate) instead of the local embedded
# ContextGuard. Both keys must be set to activate this — an Admin key (for one-time
# agent bootstrap/approval) and an Evaluate key (for the actual runtime decision
# calls). Get these from your AutoPIL trial account's Keys page. See
# examples/fraud_investigation/saas_guard.py for what this does and what's verified.
# AUTOPIL_ADMIN_KEY=your-admin-key-here
# AUTOPIL_EVALUATE_KEY=your-evaluate-key-here
# AUTOPIL_API_URL=https://autopil-api.onrender.com
